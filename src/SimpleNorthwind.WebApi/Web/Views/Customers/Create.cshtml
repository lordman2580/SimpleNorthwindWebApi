@model CustomerFormViewModel
@{
    ViewData["Title"] = "新增客戶";
}

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">新增客戶</h1>
    <a href="/customers" class="btn btn-outline-secondary">返回清單</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div asp-validation-summary="All" class="text-danger small mb-3"></div>

        <form asp-controller="CustomersUi" asp-action="Create" method="post" autocomplete="off">
            <div class="mb-3">
                <label asp-for="CompanyName" class="form-label">公司名稱 <span class="text-danger">*</span></label>
                <input asp-for="CompanyName" class="form-control" />
                <span asp-validation-for="CompanyName" class="text-danger small"></span>
            </div>
            <div class="row g-3">
                <div class="col-md-6 mb-3">
                    <label asp-for="ContactName" class="form-label"></label>
                    <input asp-for="ContactName" class="form-control" />
                    <span asp-validation-for="ContactName" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="ContactTitle" class="form-label"></label>
                    <input asp-for="ContactTitle" class="form-control" />
                    <span asp-validation-for="ContactTitle" class="text-danger small"></span>
                </div>
            </div>
            <div class="row g-3">
                <div class="col-md-6 mb-3">
                    <label asp-for="ContactNumber" class="form-label"></label>
                    <input asp-for="ContactNumber" class="form-control" />
                    <span asp-validation-for="ContactNumber" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" type="email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-teal">儲存</button>
                <a href="/customers" class="btn btn-outline-secondary">取消</a>
            </div>
        </form>
    </div>
</div>
