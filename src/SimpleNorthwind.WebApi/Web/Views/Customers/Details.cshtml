@model CustomerDetailViewModel
@{
    ViewData["Title"] = "客戶詳情";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-0">@Model.CompanyName</h1>
        <small class="text-muted">客戶代碼 @Model.CustomerId</small>
    </div>
    <div class="d-flex gap-2">
        <a href="/customers/@Model.CustomerId/edit" class="btn btn-teal">編輯</a>
        <a href="/customers/@Model.CustomerId/delete" class="btn btn-outline-danger">刪除</a>
        <a href="/customers" class="btn btn-outline-secondary">返回清單</a>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-lg-7">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body">
                <h2 class="h5 mb-3">基本資料</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-4">公司名稱</dt>
                    <dd class="col-sm-8">@Model.CompanyName</dd>

                    <dt class="col-sm-4">客戶代碼</dt>
                    <dd class="col-sm-8">@Model.CustomerId</dd>

                    <dt class="col-sm-4">聯絡人</dt>
                    <dd class="col-sm-8">@Model.ContactName.DisplayOrDash()</dd>

                    <dt class="col-sm-4">職稱</dt>
                    <dd class="col-sm-8">@Model.ContactTitle.DisplayOrDash()</dd>

                    <dt class="col-sm-4">電話</dt>
                    <dd class="col-sm-8">@Model.ContactNumber.DisplayOrDash()</dd>

                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrWhiteSpace(Model.Email))
                        {
                            <a href="mailto:@Model.Email">@Model.Email</a>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </dd>

                    <dt class="col-sm-4">建立者</dt>
                    <dd class="col-sm-8">@Model.CreateUser</dd>

                    <dt class="col-sm-4">建立日期</dt>
                    <dd class="col-sm-8">@Model.CreateDate.ToString(DateFmt.DateTime)</dd>

                    <dt class="col-sm-4">外訪狀態</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsOutContacted)
                        {
                            <span class="status-badge badge bg-success">已外訪</span>
                        }
                        else
                        {
                            <span class="status-badge badge bg-secondary">未外訪</span>
                        }
                    </dd>

                    <dt class="col-sm-4">外訪日期</dt>
                    <dd class="col-sm-8">@Model.OutContactedDate.DisplayOrDash(DateFmt.Date)</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body">
                <h2 class="h5 mb-3">客戶概況</h2>
                <div class="row text-center g-3">
                    <div class="col-4">
                        <div class="kpi-card">
                            <div class="kpi-value">@Model.TotalOrders</div>
                            <div class="kpi-label">累計訂單</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="kpi-card">
                            <div class="kpi-value">@Model.TotalSpent.ToString("C0")</div>
                            <div class="kpi-label">累計消費</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="kpi-card">
                            <div class="kpi-value">@Model.LastOrderDate.DisplayOrDash(DateFmt.Date)</div>
                            <div class="kpi-label">最近訂單</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <h2 class="h5 mb-3">訂單紀錄</h2>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>訂單</th>
                        <th>訂購日</th>
                        <th>狀態</th>
                        <th class="text-end">金額</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Orders.Count == 0)
                    {
                        <empty-row colspan="4" message="此客戶尚無訂單。" />
                    }
                    else
                    {
                        @foreach (var o in Model.Orders)
                        {
                            <tr>
                                <td><a href="/orders/@o.OrderId" class="text-teal text-decoration-none">訂單 #@o.OrderId</a></td>
                                <td>@o.OrderDate.ToString(DateFmt.Date)</td>
                                <td><status-badge status="@o.Status" /></td>
                                <td class="text-end">@o.Total.ToString("C0")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
