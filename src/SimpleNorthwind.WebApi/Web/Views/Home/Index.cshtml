@model DashboardViewModel
@{
    ViewData["Title"] = "總覽";
}

<div class="page-head">
    <div class="ph-title">
        <h2>營運總覽</h2>
        <p>訂單、客戶與庫存的即時概況。</p>
    </div>
    <div class="ph-actions">
        <span id="liveDot" class="live-dot" title="即時連線中" hidden>即時</span>
        <a href="/orders/create" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M11 11V5h2v6h6v2h-6v6h-2v-6H5v-2h6Z"/></svg>
            新增訂單
        </a>
    </div>
</div>

@* 即時刷新目標：dashboard-live.js 收到稽核事件 → 經 /dashboard/body 重抓並換新。 *@
<div id="dashboardBody">
    <partial name="~/Web/Views/Home/_DashboardBody.cshtml" model="Model" />
</div>

@section Scripts {
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script src="~/js/dashboard-live.js" asp-append-version="true"></script>
}
