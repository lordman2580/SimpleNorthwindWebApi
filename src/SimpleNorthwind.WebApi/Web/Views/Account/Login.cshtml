@model LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "登入";
    var isNameMode = Model.LoginMode != "id";
}
<!DOCTYPE html>
<html lang="zh-Hant" data-theme="light" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>登入 · Simple Northwind</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Noto+Sans+TC:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        (function () {
            try {
                var t = localStorage.getItem("sn-theme") || "light";
                document.documentElement.setAttribute("data-theme", t);
                document.documentElement.setAttribute("data-bs-theme", t);
            } catch (e) { }
        })();
    </script>
</head>
<body>
    <div class="login-stage">
        <div class="login-bg"></div>
        <div class="login-orb o1"></div>
        <div class="login-orb o2"></div>
        <div class="login-orb o3"></div>

        <div class="login-card">
            <div class="login-brand">
                <span class="brand-mark" style="width:46px;height:46px;border-radius:14px;">
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="#fff"><path d="M4 20V4l8 6 8-6v16h-4v-8l-4 3-4-3v8H4Z"/></svg>
                </span>
                <div>
                    <h1 style="font-size:20px;">Simple Northwind</h1>
                    <p style="font-size:13px;color:var(--text-3);margin-top:2px;">員工後台 · 請登入</p>
                </div>
            </div>

            <div class="login-divider">使用員工帳號登入</div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger py-2 mb-3" role="alert">@Model.ErrorMessage</div>
            }
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

            <form asp-controller="AccountUi" asp-action="Login" method="post" autocomplete="off">
                <input type="hidden" asp-for="ReturnUrl" />
                <input type="hidden" asp-for="LoginMode" id="loginMode" value="@Model.LoginMode" />

                <div class="seg-toggle mb-3" role="group" aria-label="登入方式">
                    <input type="radio" class="btn-check" name="modeToggle" id="modeName" autocomplete="off" @(isNameMode ? "checked" : "")>
                    <label class="btn seg-btn" for="modeName">姓名登入</label>
                    <input type="radio" class="btn-check" name="modeToggle" id="modeId" autocomplete="off" @(isNameMode ? "" : "checked")>
                    <label class="btn seg-btn" for="modeId">員工編號登入</label>
                </div>

                <div class="login-name mb-3" style="@(isNameMode ? "" : "display:none")">
                    <div class="row g-2">
                        <div class="col">
                            <label asp-for="FirstName" class="form-label"></label>
                            <input asp-for="FirstName" class="form-control" />
                        </div>
                        <div class="col">
                            <label asp-for="LastName" class="form-label"></label>
                            <input asp-for="LastName" class="form-control" />
                        </div>
                    </div>
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                    <div class="form-text mt-1">姓名區分大小寫（case-sensitive）。</div>
                </div>

                <div class="login-id mb-3" style="@(isNameMode ? "display:none" : "")">
                    <label asp-for="EmployeeId" class="form-label"></label>
                    <input asp-for="EmployeeId" class="form-control" inputmode="numeric" />
                    <span asp-validation-for="EmployeeId" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label"></label>
                </div>

                <button type="submit" class="btn btn-primary w-100" style="padding:12px;font-size:14.5px;">登入</button>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/tz.js"></script>
    <script>
        (function () {
            var modeInput = document.getElementById("loginMode");
            var nameGroup = document.querySelector(".login-name");
            var idGroup = document.querySelector(".login-id");
            function apply(mode) {
                modeInput.value = mode;
                nameGroup.style.display = mode === "id" ? "none" : "";
                idGroup.style.display = mode === "id" ? "" : "none";
            }
            document.getElementById("modeName").addEventListener("change", function () { apply("name"); });
            document.getElementById("modeId").addEventListener("change", function () { apply("id"); });
        })();
    </script>
</body>
</html>
