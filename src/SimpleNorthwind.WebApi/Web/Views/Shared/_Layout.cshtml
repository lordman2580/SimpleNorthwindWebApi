@{
    var userName = User.Identity?.Name;
    var title = User.FindFirst("title")?.Value;
    var path = (Context.Request.Path.Value ?? "/").ToLowerInvariant();
    string Active(string prefix) =>
        (prefix == "/" ? path == "/" : path.StartsWith(prefix)) ? "active" : "";
    var navItems = new[]
    {
        ("/", "總覽", Active("/")),
        ("/orders", "訂單", Active("/orders")),
        ("/customers", "客戶", Active("/customers")),
        ("/products", "產品", Active("/products")),
        ("/employees", "員工", Active("/employees")),
        ("/apilogs", "稽核", Active("/apilogs")),
    };
}
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Simple Northwind</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <aside class="sn-sidebar" id="snSidebar">
        <a class="sn-brand" asp-controller="HomeUi" asp-action="Index">Simple Northwind</a>
        <nav class="nav flex-column">
            @foreach (var (url, label, active) in navItems)
            {
                <a class="nav-link @active" href="@url">@label</a>
            }
        </nav>
    </aside>

    <div class="sn-main">
        <header class="sn-topbar">
            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-sm btn-outline-secondary d-md-none" type="button" onclick="document.getElementById('snSidebar').classList.toggle('show')">☰</button>
                <h1 class="h5 mb-0">@ViewData["Title"]</h1>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="text-muted small">
                    @userName@(string.IsNullOrEmpty(title) ? "" : $"（{title}）")
                </span>
                <form asp-controller="AccountUi" asp-action="Logout" method="post" class="m-0">
                    <button type="submit" class="btn btn-outline-secondary btn-sm">登出</button>
                </form>
            </div>
        </header>

        <main class="sn-content">
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/tz.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
