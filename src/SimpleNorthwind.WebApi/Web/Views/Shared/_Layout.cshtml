@{
    var userName = User.Identity?.Name;
    var title = User.FindFirst("title")?.Value;
    var pageTitle = ViewData["Title"]?.ToString() ?? "總覽";
    var path = (Context.Request.Path.Value ?? "/").ToLowerInvariant();
    string Active(string prefix) =>
        (prefix == "/" ? path == "/" : path.StartsWith(prefix)) ? "active" : "";

    // 使用者頭像縮寫（姓名首字）。
    var initial = string.IsNullOrWhiteSpace(userName) ? "員" : userName!.Trim()[..1];

    // 導覽分組（標籤 / 連結 / 圖示鍵 / active）。
    var navGroups = new (string Label, (string Url, string Text, string Ico)[] Items)[]
    {
        ("營運", new[]
        {
            ("/", "總覽", "dashboard"),
            ("/orders", "訂單", "orders"),
            ("/customers", "客戶", "customers"),
        }),
        ("目錄", new[]
        {
            ("/products", "產品", "products"),
            ("/employees", "員工", "employees"),
        }),
        ("稽核", new[]
        {
            ("/apilogs", "API 稽核", "audit"),
        }),
    };

    // 實心圓潤圖示（fill currentColor）。
    string Ico(string key) => key switch
    {
        "dashboard" => "<path d='M3 3h7v7H3V3Zm0 11h7v7H3v-7ZM14 3h7v7h-7V3Zm0 11h7v7h-7v-7Z' rx='2'/>",
        "orders" => "<path d='M6 2h9l5 5v13a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2Zm2 9h8v2H8v-2Zm0 4h8v2H8v-2Zm0-8h5v2H8V7Z'/>",
        "customers" => "<path d='M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm0 2c-3.3 0-7 1.7-7 4.5V21h14v-3.5C16 14.7 12.3 13 9 13Zm8-2a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm1 2c-.6 0-1.2.1-1.8.2 1.1 1 1.8 2.3 1.8 3.8V21h5v-2.5c0-2.4-2.7-3.5-5-3.5Z'/>",
        "products" => "<path d='M12 2 3 7v10l9 5 9-5V7l-9-5Zm0 2.3 6.5 3.6L12 11.5 5.5 7.9 12 4.3ZM5 9.6l6 3.3v6.8l-6-3.3V9.6Z'/>",
        "employees" => "<path d='M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Zm5 4a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5Zm-4 9c0-1.7 2.7-2.6 4-2.6s4 .9 4 2.6v.5H5v-.5ZM14 8h5v2h-5V8Zm0 4h5v2h-5v-2Z'/>",
        "audit" => "<path d='M12 2 4 5v6c0 5 3.4 9.4 8 11 4.6-1.6 8-6 8-11V5l-8-3Zm-1 13-3.5-3.5 1.4-1.4L11 12.2l4.1-4.1 1.4 1.4L11 15Z'/>",
        _ => "<circle cx='12' cy='12' r='4'/>"
    };
}
<!DOCTYPE html>
<html lang="zh-Hant" data-theme="light" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle · Simple Northwind</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Noto+Sans+TC:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        // 主題：避免閃爍，於 paint 前套用儲存值。
        (function () {
            try {
                var t = localStorage.getItem("sn-theme") || "light";
                var el = document.documentElement;
                el.setAttribute("data-theme", t);
                el.setAttribute("data-bs-theme", t);
            } catch (e) { }
        })();
    </script>
</head>
<body>
    <div class="app" id="app">
        <aside class="sidebar" id="snSidebar">
            <a class="brand" asp-controller="HomeUi" asp-action="Index">
                <span class="brand-mark">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M4 20V4l8 6 8-6v16h-4v-8l-4 3-4-3v8H4Z"/></svg>
                </span>
                <span class="brand-name">
                    <b>Simple Northwind</b>
                    <span>管理系統</span>
                </span>
            </a>

            @foreach (var group in navGroups)
            {
                <div class="nav-group-label">@group.Label</div>
                @foreach (var (url, text, ico) in group.Items)
                {
                    <a class="nav-item @Active(url == "/" ? "/" : url)" href="@url">
                        <svg class="nav-ico" width="19" height="19" viewBox="0 0 24 24" fill="currentColor">@Html.Raw(Ico(ico))</svg>
                        <span class="lbl">@text</span>
                    </a>
                }
            }

            <div class="sidebar-foot">
                <div class="sidebar-user">
                    <span class="avatar">@initial</span>
                    <span class="who">
                        <b>@(userName ?? "員工")</b>
                        <span>@(string.IsNullOrEmpty(title) ? "已登入" : title)</span>
                    </span>
                    <form asp-controller="AccountUi" asp-action="Logout" method="post" class="m-0 d-flex">
                        <button type="submit" class="sidebar-logout" title="登出" aria-label="登出">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M10 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h5v-2H5V5h5V3Zm6.2 4.2-1.4 1.4L17.2 11H9v2h8.2l-2.4 2.4 1.4 1.4L21 12l-4.8-4.8Z"/></svg>
                        </button>
                    </form>
                </div>
            </div>
        </aside>

        <div class="main">
            <header class="topbar">
                <button class="icon-btn menu-btn" type="button" id="snMenuBtn" aria-label="切換側欄">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M3 6h18v2H3V6Zm0 5h18v2H3v-2Zm0 5h18v2H3v-2Z"/></svg>
                </button>
                <div class="crumbs">
                    Simple Northwind <span>/</span> <b>@pageTitle</b>
                </div>
                <div class="page-title-wrap">
                    <h1>@pageTitle</h1>
                </div>

                <label class="search" aria-label="搜尋">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M10 2a8 8 0 1 0 4.9 14.3l5.4 5.4 1.4-1.4-5.4-5.4A8 8 0 0 0 10 2Zm0 2a6 6 0 1 1 0 12 6 6 0 0 1 0-12Z"/></svg>
                    <input type="search" placeholder="搜尋…" />
                </label>

                <button class="icon-btn" type="button" id="snThemeBtn" aria-label="切換深色模式">
                    <svg class="theme-sun" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17a5 5 0 1 0 0-10 5 5 0 0 0 0 10Zm0-13h0V1m0 22v-3m8-7h3M1 12h3m13.7-6.7 2.1-2.1M4.2 19.8l2.1-2.1m11.4 0 2.1 2.1M4.2 4.2l2.1 2.1" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
                </button>
            </header>

            <main class="content">
                <div class="content-inner route-fade">
                    <partial name="~/Web/Views/Shared/_FlashMessages.cshtml" />
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/tz.js" asp-append-version="true"></script>
    <script>
        // 主題切換（持久化）。
        document.getElementById("snThemeBtn").addEventListener("click", function () {
            var el = document.documentElement;
            var next = el.getAttribute("data-theme") === "dark" ? "light" : "dark";
            el.setAttribute("data-theme", next);
            el.setAttribute("data-bs-theme", next);
            try { localStorage.setItem("sn-theme", next); } catch (e) { }
        });
        // 側欄切換：窄螢幕滑出、寬螢幕收合為圖示。
        document.getElementById("snMenuBtn").addEventListener("click", function () {
            var app = document.getElementById("app");
            if (window.matchMedia("(max-width: 860px)").matches) app.classList.toggle("sb-open");
            else app.classList.toggle("collapsed");
        });
        // 點側欄外的遮罩關閉（窄螢幕）。
        document.getElementById("app").addEventListener("click", function (e) {
            if (this.classList.contains("sb-open") && !e.target.closest("#snSidebar") && !e.target.closest("#snMenuBtn")) {
                this.classList.remove("sb-open");
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
