{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/simplenorthwind-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ]
  },
  "ConnectionStrings": {
    "SimpleNorthwind": "enc:REPLACE_WITH_AES256GCM_CIPHERTEXT"
  },
  "Jwt": {
    "Secret": "enc:REPLACE_WITH_AES256GCM_CIPHERTEXT"
  }
}
